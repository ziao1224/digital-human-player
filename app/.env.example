# ============================================
# 火山引擎语音合成 2.0 (Doubao-Seed-TTS 2.0)
# ============================================
# 文档：https://www.volcengine.com/docs/6561/1329505

# 1. 访问 https://console.volcengine.com/speech/app 创建应用
# 2. 开通 "语音合成大模型 2.0" 服务
# 3. 获取 App ID 和 Access Key

VITE_VOLCANO_APP_ID=your_app_id_here
VITE_VOLCANO_ACCESS_KEY=your_access_key_here

# 可选：选择语音类型（2.0版本 - 用于数字人视频TTS）
# 推荐：zh_female_vv_saturn_bigtts（星悦，女声，青春活泼）
# 其他选项：zh_female_vv_uranus_bigtts（星念，女声，最自然）
#           zh_male_vv_mars_bigtts（星朗，男声，沉稳成熟）
VITE_VOLCANO_SPEAKER=zh_female_vv_saturn_bigtts

# 可选：语速（0.5-2.0，1.0为正常）
VITE_VOLCANO_SPEED=1.1

# 可选：语音问答Realtime API音色（端到端实时语音模型）
# 推荐：zh_female_vv_jupiter_bigtts（vv，活泼灵动女声）
# 其他选项：zh_female_xiaohe_jupiter_bigtts（xiaohe，甜美活泼台湾腔）
#           zh_male_yunzhou_jupiter_bigtts（yunzhou，清爽沉稳男声）
VITE_VOLCANO_REALTIME_SPEAKER=zh_female_vv_jupiter_bigtts

# ============================================
# AI 问答配置（Deepseek）
# ============================================
VITE_DEEPSEEK_API_KEY=sk-your-api-key-here
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
VITE_DEEPSEEK_MODEL=deepseek-chat

# ============================================
# Coze 智能语音对话（WebSocket OpenAPI）
# ============================================
# 用于验证 Coze 语音对话方案的 PoC
# 1. 在 https://www.coze.cn 创建智能体并发布为 API 服务
# 2. 获取 Bot ID（开发页面 URL 中 bot 参数后的数字）
# 3. 在「设置 → 个人访问令牌」中创建 PAT Token

VITE_COZE_BOT_ID=your_bot_id_here
VITE_COZE_TOKEN=pat_your_token_here

# ============================================
# 火山引擎 RTC + StartVoiceChat 级联语音对话
# ============================================
# 用于 /voice-chat-rtc 页面的级联方案验证
# 1. 在 https://console.volcengine.com/rtc 创建 RTC 应用，获取 AppId 和 AppKey
# 2. 在 https://console.volcengine.com/iam/keymanage 获取 AK/SK
# 3. 需开通 RTC、ASR、TTS、LLM 服务并完成跨服务授权

VOLCANO_RTC_APP_ID=your_rtc_app_id_here
VOLCANO_RTC_APP_KEY=your_rtc_app_key_here
VOLCANO_AK=your_access_key_here
VOLCANO_SK=your_secret_key_here

# 可选：Coze 知识库配置（用于 StartVoiceChat 的 LLMConfig）
# 注意：使用 CozeBot 需要 OutputMode != 0 且开通 Function Calling
COZE_BOT_ID=your_bot_id_here
COZE_TOKEN=pat_your_token_here

# ============================================
# 后端服务配置（用于 PPT 转图片）
# ============================================
VITE_SERVER_URL=http://localhost:3001

# 数字人视频生成服务 (Python SadTalker)
VITE_AVATAR_SERVICE_URL=http://localhost:8008
